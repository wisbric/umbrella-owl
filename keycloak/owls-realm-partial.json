{
  "ifResourceExists": "SKIP",
  "clients": [
    {
      "clientId": "nightowl",
      "name": "NightOwl (Owlstack)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "NIGHTOWL_OIDC_SECRET_PLACEHOLDER",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "OWLSTACK_BASE_URL_PLACEHOLDER/*"
      ],
      "webOrigins": [
        "OWLSTACK_BASE_URL_PLACEHOLDER"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "groups"
      ]
    },
    {
      "clientId": "keep",
      "name": "Keep (AIOps Alerts)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "KEEP_OIDC_SECRET_PLACEHOLDER",
      "standardFlowEnabled": true,
      "redirectUris": [
        "KEEP_BASE_URL_PLACEHOLDER/*",
        "KEEP_BASE_URL_PLACEHOLDER/oauth2/callback"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "groups"
      ]
    },
    {
      "clientId": "outline",
      "name": "Outline (Wiki)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "OUTLINE_OIDC_SECRET_PLACEHOLDER",
      "standardFlowEnabled": true,
      "redirectUris": [
        "OUTLINE_BASE_URL_PLACEHOLDER/*",
        "OUTLINE_BASE_URL_PLACEHOLDER/auth/oidc.callback"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "groups"
      ]
    }
  ]
}
